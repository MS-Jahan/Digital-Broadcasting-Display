# Digital Broadcasting Display - Environment Configuration
# Copy this file to .env and customize the values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Flask environment (development/production)
FLASK_ENV=production

# Secret key for session management (CHANGE THIS!)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Debug mode (true/false)
DEBUG=false

# Application version
VERSION=latest

# =============================================================================
# DATABASE SETTINGS
# =============================================================================

# Database file path (relative to container)
DATABASE_PATH=/app/data/database.sqlite

# Backup settings
BACKUP_ON_START=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION=7

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Admin credentials (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# =============================================================================
# SERVER SETTINGS
# =============================================================================

# Host port mapping (external:internal)
HOST_PORT=8082

# Domain name (for reverse proxy)
DOMAIN=localhost

# Upload folder name
UPLOAD_FOLDER=videos

# =============================================================================
# NGINX SETTINGS (if using nginx service)
# =============================================================================

# Nginx port mappings
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================

# Webhook URL for backup notifications (optional)
NOTIFICATION_WEBHOOK=

# Email notifications for Watchtower (optional)
WATCHTOWER_NOTIFICATIONS=
EMAIL_FROM=
EMAIL_TO=
EMAIL_SERVER=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# =============================================================================
# WATCHTOWER SETTINGS (auto-update service)
# =============================================================================

# Update check interval in seconds
WATCHTOWER_INTERVAL=3600

# =============================================================================
# BUILD SETTINGS
# =============================================================================

# Build timestamp (automatically set)
BUILD_DATE=

# Git commit hash (automatically set)
VCS_REF=
